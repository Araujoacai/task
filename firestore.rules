rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra Global: fechar o banco por padrão. Nada se lê ou escreve.
    match /{document=**} {
      allow read, write: if false;
    }

    // Regra específica para a coleção "tarefas"
    match /tarefas/{taskId} {
      
      // Um usuário SÓ PODE LER se estiver autenticado e for o dono da tarefa (userId bate com o seu uid)
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Um usuário SÓ PODE CRIAR se estiver autenticado E o userId que ele está enviando for o próprio UID dele
      // Impede que um mal-intencionado crie uma tarefa no nome de outra pessoa
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Um usuário SÓ PODE ATUALIZAR/DELETAR se estiver autenticado, for o dono da tarefa 
      // e, na atualização, não tentar mudar o dono da tarefa (userId deve permanecer igual)
      allow update: if request.auth != null 
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
                    
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
